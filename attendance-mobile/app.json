{
  "expo": {
    "name": "AssistControl",
    "slug": "attendance-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./aiattendance-logo.png",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.abisoft.assistcontrol",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Se usa para registrar tu ubicación al marcar entrada/salida.",
        "NSLocationAlwaysUsageDescription": "Se usa para enviarte recordatorios de asistencia."
      }
    },
    "android": {
      "package": "com.abisoft.assistcontrol",
      "adaptiveIcon": {
        "foregroundImage": "./aiattendance-logo.png",
        "backgroundColor": "#0f172a"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Se usa para registrar tu ubicación al marcar asistencia."
        }
      ],
      "expo-notifications",
      "expo-font",
      "expo-asset"
    ],
    "scheme": "attendance",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
