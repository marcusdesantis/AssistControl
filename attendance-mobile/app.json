{
  "expo": {
    "name": "TiempoYa",
    "slug": "attendance-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.abisoft.tiempoya",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Se usa para registrar tu ubicación al marcar entrada/salida.",
        "NSLocationAlwaysUsageDescription": "Se usa para enviarte recordatorios de asistencia."
      }
    },
    "android": {
      "package": "com.abisoft.tiempoya",
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#0f172a"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Se usa para registrar tu ubicación al marcar asistencia."
        }
      ],
      "expo-notifications",
      "expo-font",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      "./plugins/withKotlinVersion"
    ],
    "scheme": "attendance",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "03665f3e-8e79-489e-9984-5480c7486d79"
      }
    },
    "owner": "yasmani1997"
  }
}
