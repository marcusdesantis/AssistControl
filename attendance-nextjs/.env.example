# ─── Base de datos ─────────────────────────────────────────────────────────────
# Dentro de Docker los servicios se conectan al contenedor "postgres"
DATABASE_URL=postgresql://postgres:CAMBIA_ESTO@postgres:5432/attendance

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=CAMBIA_ESTO_por_una_cadena_aleatoria_larga
JWT_EXPIRES_IN=1440m

# ─── Superadmin ────────────────────────────────────────────────────────────────
SUPERADMIN_JWT_SECRET=CAMBIA_ESTO_por_otra_cadena_aleatoria_larga

# ─── Puerto nginx (acceso desde el navegador) ──────────────────────────────────
NGINX_PORT=80

# ─── URLs públicas ─────────────────────────────────────────────────────────────
APP_URL=https://tu-dominio.com
FRONTEND_URL=https://tu-dominio.com

# ─── Payphone (pasarela de pago) ───────────────────────────────────────────────
PAYPHONE_TOKEN=
PAYPHONE_STORE_ID=

# ─── PostgreSQL (credenciales del contenedor) ──────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIA_ESTO
POSTGRES_DB=attendance
